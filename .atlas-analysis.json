  "keyFeatures": [
    "OAuth 2.0 client credentials authentication with scoped access tokens",
    "SIM card and subscriber lifecycle management (activate, modify, suspend, terminate)",
    "Mobile number portability for Belgium, France, UK, and Switzerland",
    "IoT subscriber lifecycle with test mode and tariff holiday support",
    "Network attach history and remote SIM detach",
    "Inbound and outbound SMS messaging with delivery reports",
    "Over-the-air (OTA) private network switching",
    "Active data session monitoring by MSISDN or IMSI",
    "Detailed CDR retrieval and usage aggregation for data, voice, SMS, and MMS",
    "OCS product catalog management with one-off, recurring, and add-on products",
    "Real-time webhook events for subscriber state changes and portability updates",
    "SIM card details retrieval (PIN, PUK, electrical profile)"
  ],
